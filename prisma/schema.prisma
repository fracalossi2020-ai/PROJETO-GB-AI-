generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  cpf       String?
  role      String   @default("OWNER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stores       Store[]
  subscription Subscription?

  @@map("users")
}

model Subscription {
  id       String @id @default(cuid())
  plan     String @default("GRATUITO") // GRATUITO, BASICO, PREMIUM
  status   String @default("ATIVO") // ATIVO, CANCELADO, SUSPENSO
  price    Float  @default(0)
  expiresAt DateTime?

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  @@map("subscriptions")
}

model Store {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  logo        String?
  coverImage  String?

  // Dados do estabelecimento
  phone       String
  whatsapp    String?
  email       String?
  address     String?
  city        String?
  state       String?
  zipCode     String?
  cnpj        String?
  cpf         String?

  // Configurações visuais
  themeColor  String  @default("#ff9607")
  isActive    Boolean @default(true)
  isOpen      Boolean @default(true)

  // Configurações de pedido
  deliveryFee      Float   @default(0)
  minOrderValue    Float   @default(0)
  deliveryTimeMin  Int     @default(30)
  deliveryTimeMax  Int     @default(60)

  // Pagamentos
  acceptCash       Boolean @default(true)
  acceptCard       Boolean @default(true)
  acceptPix        Boolean @default(true)
  pixKey           String?
  acceptOnlineCard Boolean @default(false)

  // Modos de operação
  hasDelivery      Boolean @default(true)
  hasPickup        Boolean @default(true)
  hasDineIn        Boolean @default(false)

  // Salão
  tableCount       Int     @default(0)
  commandCount     Int     @default(0)
  hasWaiters       Boolean @default(false)
  serviceFee       Float   @default(0)

  // Configurações
  autoAcceptOrders Boolean @default(false)
  autoPrint        Boolean @default(false)

  // WhatsApp e integrações
  whatsappNumber   String?
  ifoodIntegrated  Boolean @default(false)
  ifoodMerchantId  String?
  robotEnabled     Boolean @default(false)

  // Tipo de estabelecimento
  businessType     String @default("RESTAURANTE")

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  categories     Category[]
  products       Product[]
  customers      Customer[]
  orders         Order[]
  deliveryZones  DeliveryZone[]
  deliveryPeople DeliveryPerson[]
  businessHours  BusinessHour[]
  tables         Table[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("stores")
}

model BusinessHour {
  id        String @id @default(cuid())
  dayOfWeek Int    // 0=Domingo, 1=Segunda...
  openTime  String // "08:00"
  closeTime String // "22:00"
  isOpen    Boolean @default(true)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("business_hours")
}

model Category {
  id        String @id @default(cuid())
  name      String
  icon      String?
  image     String?
  sortOrder Int    @default(0)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  products Product[]

  @@map("categories")
}

model Product {
  id          String  @id @default(cuid())
  name        String
  description String?
  image       String?
  price       Float
  costPrice   Float?
  isActive    Boolean @default(true)
  isFeatured  Boolean @default(false)
  isPromotion Boolean @default(false)
  promotionPrice Float?
  stock       Int     @default(999)
  sortOrder   Int     @default(0)

  storeId String
  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  addons     ProductAddon[]
  orderItems OrderItem[]

  @@map("products")
}

model ProductAddon {
  id    String @id @default(cuid())
  name  String
  price Float  @default(0)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  orderItemAddons OrderItemAddon[]

  @@map("product_addons")
}

model Customer {
  id           String  @id @default(cuid())
  name         String
  phone        String
  email        String?
  cpf          String?
  address      String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?
  zipCode      String?

  storeId String
  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  orders Order[]

  @@unique([storeId, phone])
  @@map("customers")
}

model Order {
  id            String @id @default(cuid())
  orderNumber   String? // Número sequencial por loja: 001, 002, 003...
  status        String @default("NOVO") // NOVO, EM_PREPARO, SAIU_PARA_ENTREGA, PRONTO_RETIRADA, ENTREGUE, CANCELADO
  type          String @default("DELIVERY") // DELIVERY, PICKUP, DINE_IN
  paymentMethod String @default("PIX") // PIX, DINHEIRO, CARTAO_CREDITO, CARTAO_DEBITO, VALE_REFEICAO
  changeFor     Float?

  subtotal    Float
  deliveryFee Float @default(0)
  discount    Float @default(0)
  serviceFee  Float @default(0)
  total       Float

  customerNote String?
  internalNote String?
  tableNumber  String?

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  items OrderItem[]
  deliveryAssignments DeliveryAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("orders")
}

model OrderItem {
  id         String @id @default(cuid())
  quantity   Int
  unitPrice  Float
  totalPrice Float
  note       String?

  orderId String
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  addons OrderItemAddon[]

  @@map("order_items")
}

model OrderItemAddon {
  id    String @id @default(cuid())
  name  String
  price Float

  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  productAddonId String?
  productAddon   ProductAddon? @relation(fields: [productAddonId], references: [id])

  @@map("order_item_addons")
}

model DeliveryZone {
  id        String @id @default(cuid())
  name      String
  radiusKm  Float?
  neighborhoods String?
  deliveryFee Float @default(0)
  minOrderValue Float @default(0)
  estimatedTimeMin Int @default(30)
  estimatedTimeMax Int @default(60)
  isActive  Boolean @default(true)

  storeId String
  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("delivery_zones")
}

model DeliveryPerson {
  id       String  @id @default(cuid())
  code     String? // E1, E2, E3...
  name     String
  phone    String?
  vehicle  String  @default("MOTO") // MOTO, BIKE, CARRO
  isActive Boolean @default(true)
  feePerDelivery Float @default(0)

  storeId String
  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  assignments DeliveryAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, code])
  @@map("delivery_people")
}

model DeliveryAssignment {
  id     String @id @default(cuid())
  status String @default("PENDENTE") // PENDENTE, EM_ANDAMENTO, ENTREGUE, CANCELADO
  fee    Float  @default(0)
  paid   Boolean @default(false)
  paidAt DateTime?

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  deliveryPersonId String
  deliveryPerson   DeliveryPerson @relation(fields: [deliveryPersonId], references: [id], onDelete: Cascade)

  assignedAt  DateTime  @default(now())
  deliveredAt DateTime?

  @@map("delivery_assignments")
}

model Table {
  id      String @id @default(cuid())
  number  String
  qrCode  String?
  isActive Boolean @default(true)

  storeId String
  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("tables")
}
